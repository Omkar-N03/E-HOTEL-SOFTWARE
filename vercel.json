{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "admin/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "customer/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "kitchen/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "SuperAdmin/**/*.php": { "runtime": "vercel-php@0.7.0" },
    "*.php": { "runtime": "vercel-php@0.7.0" }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(api|admin|customer|kitchen|SuperAdmin)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
